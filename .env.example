DB_DATABASE=brill_lash_and_beauty
DB_USERNAME=brill
DB_PASSWORD=change_this_password
DB_ROOT_PASSWORD=change_this_root_password

SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

VITE_APP_NAME="${APP_NAME}"
